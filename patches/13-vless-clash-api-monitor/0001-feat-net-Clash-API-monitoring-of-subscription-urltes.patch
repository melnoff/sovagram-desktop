+void ProxyBox::startSubscriptionMonitorIfRunning(
+		const QString &subscriptionUrl) {
+	const auto endpoint = MTP::Proxy::VlessBridge::instance()
+		.clashEndpointForSubscription(subscriptionUrl);
+	if (!endpoint) {
+		_subMonitor.reset();
+		return;
+	}
+	_subMonitor = std::make_unique<MTP::Proxy::SubscriptionMonitor>(
+		endpoint->endpoint,
+		endpoint->secret);
+	_subMonitor->status(
+	) | rpl::on_next([=](MTP::Proxy::SubscriptionMonitorStatus status) {
+		_subMonitorStatus = std::move(status);
+		renderSubscriptionEntry(_subEntry);
+	}, lifetime());
+	_subMonitor->start();
+}
