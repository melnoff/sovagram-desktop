new file mode 100644
index 0000000000..e34f4fb352
--- /dev/null
+++ b/Telegram/SourceFiles/mtproto/proxy/subscription_monitor.cpp
@@ -0,0 +1,121 @@
+/*
+This file is part of Telegram Desktop,
+the official desktop application for the Telegram messaging service.
+
+For license and copyright information please follow this link:
+https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
+*/
+#include "mtproto/proxy/subscription_monitor.h"
+
+#include "logs.h"
+
+#include <QtCore/QJsonArray>
+#include <QtCore/QJsonDocument>
+#include <QtCore/QJsonObject>
+#include <QtCore/QUrl>
+#include <QtNetwork/QNetworkReply>
+#include <QtNetwork/QNetworkRequest>
+
+namespace MTP::Proxy {
+namespace {
+
+constexpr auto kPollInterval = 3000;
+constexpr auto kRequestTimeout = 2500;
+
+} // namespace
+
+SubscriptionMonitor::SubscriptionMonitor(
+	const QString &endpoint,
+	const QString &secret,
+	QObject *parent)
+: QObject(parent)
+, _endpoint(endpoint)
+, _secret(secret) {
+	_timer.setInterval(kPollInterval);
+	QObject::connect(&_timer, &QTimer::timeout, this, [=] { poll(); });
+}
+
+SubscriptionMonitor::~SubscriptionMonitor() {
+	stop();
+}
+
+void SubscriptionMonitor::start() {
+	if (_timer.isActive()) {
+		return;
+	}
+	_timer.start();
+	poll();
+}
+
+void SubscriptionMonitor::stop() {
+	_timer.stop();
+	if (_current) {
+		_current->disconnect(this);
+		_current->abort();
+		_current->deleteLater();
+		_current = nullptr;
+	}
+}
+
+void SubscriptionMonitor::poll() {
+	if (_current) {
+		return;
+	}
+	const auto url = QUrl(QStringLiteral("http://%1/proxies").arg(_endpoint));
+	auto request = QNetworkRequest(url);
+	request.setRawHeader(
+		"Authorization",
+		"Bearer " + _secret.toUtf8());
+	request.setTransferTimeout(kRequestTimeout);
+	const auto reply = _net.get(request);
+	_current = reply;
+	QObject::connect(reply, &QNetworkReply::finished, this, [=] {
+		handleReply(reply);
+	});
+}
+
+void SubscriptionMonitor::handleReply(QNetworkReply *reply) {
+	reply->deleteLater();
+	if (reply != _current) {
+		return;
+	}
+	_current = nullptr;
+
+	if (reply->error() != QNetworkReply::NoError) {
+		_status.fire({ {}, reply->errorString(), {} });
+		return;
+	}
+	const auto doc = QJsonDocument::fromJson(reply->readAll());
+	if (!doc.isObject()) {
+		_status.fire({ {}, QStringLiteral("Bad Clash API response."), {} });
+		return;
+	}
+	const auto proxies = doc.object().value(u"proxies"_q).toObject();
+	const auto selector = proxies.value(u"proxy"_q).toObject();
+	const auto activeTag = selector.value(u"now"_q).toString();
+	const auto allTags = selector.value(u"all"_q).toArray();
+
+	QList<SubscriptionServerStatus> servers;
+	servers.reserve(allTags.size());
+	for (const auto &t : allTags) {
+		const auto tag = t.toString();
+		if (tag.isEmpty()) {
+			continue;
+		}
+		const auto entry = proxies.value(tag).toObject();
+		const auto history = entry.value(u"history"_q).toArray();
+		auto delayMs = -1;
+		if (!history.isEmpty()) {
+			const auto last = history.last().toObject();
+			delayMs = last.value(u"delay"_q).toInt(-1);
+		}
+		servers.append({ tag, delayMs });
+	}
+	_status.fire({ activeTag, QString(), std::move(servers) });
+}
+
+rpl::producer<SubscriptionMonitorStatus> SubscriptionMonitor::status() {
+	return _status.events();
+}
+
+} // namespace MTP::Proxy
