+std::optional<VlessBridge::ClashEndpoint>
+VlessBridge::clashEndpointForSubscription(const QString &subscriptionKey) {
+	QMutexLocker lock(&_mu);
+	const auto it = _runningSubscriptions.find(subscriptionKey);
+	if (it == _runningSubscriptions.end() || it->second.clashPort == 0) {
+		return std::nullopt;
+	}
+	return ClashEndpoint{
+		.endpoint = QStringLiteral("127.0.0.1:%1").arg(it->second.clashPort),
+		.secret = it->second.clashSecret,
+	};
+}
