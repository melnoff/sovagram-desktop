+/*
+This file is part of Telegram Desktop,
+the official desktop application for the Telegram messaging service.
+
+For license and copyright information please follow this link:
+https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
+*/
+#pragma once
+
+#include <QtCore/QObject>
+#include <QtCore/QPointer>
+#include <QtCore/QTimer>
+#include <QtNetwork/QNetworkAccessManager>
+
+class QNetworkReply;
+
+namespace MTP::Proxy {
+
+struct SubscriptionServerStatus {
+	QString tag;       // sing-box outbound tag, e.g. "v0"
+	int delayMs = -1;  // last measured delay; -1 if unknown / timeout
+};
+
+struct SubscriptionMonitorStatus {
+	QString activeTag;                       // currently selected by urltest
+	QString error;                           // empty on success
+	QList<SubscriptionServerStatus> servers; // one entry per "vN" tag
+};
+
+// Polls a sing-box Clash API endpoint every few seconds and emits which
+// outbound the urltest selector currently considers active plus the last
+// delay measurement for every server in the subscription. Owned per
+// edit-dialog instance — destroying the monitor stops the timer.
+class SubscriptionMonitor final : public QObject {
+public:
+	SubscriptionMonitor(
+		const QString &endpoint,
+		const QString &secret,
+		QObject *parent = nullptr);
+	~SubscriptionMonitor();
+
+	void start();
+	void stop();
+
+	[[nodiscard]] rpl::producer<SubscriptionMonitorStatus> status();
+
+private:
+	void poll();
+	void handleReply(QNetworkReply *reply);
+
+	QString _endpoint;
+	QString _secret;
+	QTimer _timer;
+	QNetworkAccessManager _net;
+	QPointer<QNetworkReply> _current;
+	rpl::event_stream<SubscriptionMonitorStatus> _status;
+};
+
+} // namespace MTP::Proxy
