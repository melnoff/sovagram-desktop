diff --git a/Telegram/SourceFiles/settings/sections/settings_advanced.cpp b/Telegram/SourceFiles/settings/sections/settings_advanced.cpp
index ece7d62581..998e133cea 100644
--- a/Telegram/SourceFiles/settings/sections/settings_advanced.cpp
+++ b/Telegram/SourceFiles/settings/sections/settings_advanced.cpp
@@ -1181,6 +1181,40 @@ void BuildExportSection(SectionBuilder &builder) {
 	});
 }
 
+void BuildRoundVideosSection(SectionBuilder &builder) {
+	builder.addDivider();
+	builder.addSkip();
+	builder.addSubsectionTitle({
+		.id = u"advanced/round_videos"_q,
+		.title = tr::lng_settings_round_videos_section(),
+		.keywords = { u"round"_q, u"video"_q, u"notes"_q, u"circles"_q },
+	});
+
+	const auto toggle = builder.addButton({
+		.id = u"advanced/round_videos_hide"_q,
+		.title = tr::lng_settings_hide_round_videos(),
+		.st = &st::settingsButtonNoIcon,
+		.toggled = rpl::single(Core::App().settings().readPref<bool>(
+			Core::kHideRoundVideosKey)),
+		.keywords = { u"round"_q, u"video"_q, u"notes"_q, u"circles"_q },
+	});
+
+	if (toggle) {
+		toggle->toggledValue(
+		) | rpl::filter([=](bool value) {
+			return (value != Core::App().settings().readPref<bool>(
+				Core::kHideRoundVideosKey));
+		}) | rpl::on_next([=](bool value) {
+			Core::App().settings().writePref<bool>(
+				Core::kHideRoundVideosKey,
+				value);
+			Core::App().saveSettingsDelayed();
+		}, toggle->lifetime());
+	}
+
+	builder.addSkip();
+}
+
 void BuildScreenReaderSection(SectionBuilder &builder) {
 	const auto detected = base::ScreenReaderState::Instance()->active();
 	const auto disabled = Ui::ScreenReaderModeDisabled();
@@ -1253,6 +1287,7 @@ const auto kMeta = BuildHelper({
 	BuildSystemIntegrationSection(builder);
 	BuildPerformanceSection(builder);
 	BuildSpellcheckerSection(builder);
+	BuildRoundVideosSection(builder);
 	BuildScreenReaderSection(builder);
 	if (autoUpdate) {
 		BuildUpdateSection(builder, false);
