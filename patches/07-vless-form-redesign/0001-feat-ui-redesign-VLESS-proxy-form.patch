+		field->changes() | rpl::on_next(rebuild, field->lifetime());
+	}
+	_vlessAllowInsecure->checkedChanges() | rpl::on_next(
+		[=](bool) { rebuild(); },
+		_vlessAllowInsecure->lifetime());
+
+	if (data.type == Type::Vless && !data.host.isEmpty()) {
+		syncVlessFromUrl();
+	}
