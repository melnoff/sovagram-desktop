+	makeRow(QStringLiteral("Fingerprint (utls)"),          _vlessFingerprint);
+	makeRow(QStringLiteral("Reality public key"),          _vlessPublicKey);
+	makeRow(QStringLiteral("Reality short ID"),            _vlessShortId);
