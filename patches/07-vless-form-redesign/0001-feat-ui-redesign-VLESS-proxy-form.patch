+
+void ProxyBox::syncVlessFromUrl() {
+	if (!_vlessUrl) return;
+	const auto parsed = MTP::Proxy::ParseVlessUrl(
+		_vlessUrl->getLastText().trimmed());
+	if (!parsed) return;
+	_vlessSyncing = true;
+	const auto setText = [](Ui::InputField *f, const QString &v) {
+		if (f && f->getLastText() != v) f->setText(v);
+	};
+	setText(_vlessServer.data(),       parsed->server);
+	setText(_vlessPort.data(),         QString::number(parsed->port));
+	setText(_vlessUuid.data(),         parsed->uuid);
+	setText(_vlessFlow.data(),         parsed->flow);
+	setText(_vlessSecurity.data(),     parsed->security);
+	setText(_vlessSni.data(),          parsed->sni);
+	setText(_vlessAlpn.data(),         parsed->alpn.join(QChar(',')));
+	setText(_vlessFingerprint.data(),  parsed->fingerprint);
+	setText(_vlessPublicKey.data(),    parsed->publicKey);
+	setText(_vlessShortId.data(),      parsed->shortId);
+	setText(_vlessTransport.data(),    parsed->transport);
+	setText(_vlessPath.data(),         parsed->path);
+	setText(_vlessHost.data(),         parsed->host);
+	setText(_vlessServiceName.data(),  parsed->serviceName);
+	setText(_vlessHeaderType.data(),   parsed->headerType);
+	setText(_vlessName.data(),         parsed->name);
+	if (_vlessAllowInsecure
+		&& _vlessAllowInsecure->checked() != parsed->allowInsecure) {
+		_vlessAllowInsecure->setChecked(
+			parsed->allowInsecure,
+			Ui::Checkbox::NotifyAboutChange::DontNotify);
+	}
+	_vlessSyncing = false;
+}
+
+void ProxyBox::syncVlessFromFields() {
+	if (!_vlessUrl) return;
+	MTP::Proxy::VlessParams p;
+	p.server      = _vlessServer ? _vlessServer->getLastText().trimmed() : QString();
+	p.port        = _vlessPort
+		? quint16(_vlessPort->getLastText().trimmed().toUInt())
+		: 0;
+	p.uuid        = _vlessUuid ? _vlessUuid->getLastText().trimmed() : QString();
+	p.flow        = _vlessFlow ? _vlessFlow->getLastText().trimmed() : QString();
+	p.security    = _vlessSecurity ? _vlessSecurity->getLastText().trimmed() : QString();
+	p.sni         = _vlessSni ? _vlessSni->getLastText().trimmed() : QString();
+	const auto alpnText = _vlessAlpn ? _vlessAlpn->getLastText().trimmed() : QString();
+	if (!alpnText.isEmpty()) {
+		p.alpn = alpnText.split(u',', Qt::SkipEmptyParts);
+		for (auto &a : p.alpn) a = a.trimmed();
+	}
+	p.fingerprint = _vlessFingerprint ? _vlessFingerprint->getLastText().trimmed() : QString();
+	p.publicKey   = _vlessPublicKey ? _vlessPublicKey->getLastText().trimmed() : QString();
+	p.shortId     = _vlessShortId ? _vlessShortId->getLastText().trimmed() : QString();
+	p.transport   = _vlessTransport ? _vlessTransport->getLastText().trimmed() : QString();
+	p.path        = _vlessPath ? _vlessPath->getLastText().trimmed() : QString();
+	p.host        = _vlessHost ? _vlessHost->getLastText().trimmed() : QString();
+	p.serviceName = _vlessServiceName ? _vlessServiceName->getLastText().trimmed() : QString();
+	p.headerType  = _vlessHeaderType ? _vlessHeaderType->getLastText().trimmed() : QString();
+	p.name        = _vlessName ? _vlessName->getLastText().trimmed() : QString();
+	p.allowInsecure = _vlessAllowInsecure && _vlessAllowInsecure->checked();
+
+	if (p.server.isEmpty() || p.port == 0 || p.uuid.isEmpty()) {
+		return;
+	}
+	const auto built = MTP::Proxy::BuildVlessUrl(p);
+	if (built.isEmpty() || _vlessUrl->getLastText() == built) {
+		return;
+	}
+	_vlessSyncing = true;
+	_vlessUrl->setText(built);
+	_vlessSyncing = false;
 }
 
 void ProxyBox::setupControls(const ProxyData &data) {
diff --git a/Telegram/SourceFiles/mtproto/proxy/vless_parser.cpp b/Telegram/SourceFiles/mtproto/proxy/vless_parser.cpp
index a921447e5a..248c61ff85 100644
--- a/Telegram/SourceFiles/mtproto/proxy/vless_parser.cpp
+++ b/Telegram/SourceFiles/mtproto/proxy/vless_parser.cpp
@@ -77,6 +77,71 @@ std::optional<VlessParams> ParseVlessUrl(const QString &input) {
 	return p.valid() ? std::optional<VlessParams>(std::move(p)) : std::nullopt;
 }
 
+QString BuildVlessUrl(const VlessParams &p) {
+	if (p.uuid.isEmpty() || p.server.isEmpty() || p.port == 0) {
+		return QString();
+	}
+	const auto encUuid = QString::fromLatin1(
+		QUrl::toPercentEncoding(p.uuid));
+	const auto encServer = p.server.contains(QChar(':'))
+		? (u"["_q + p.server + u"]"_q)
+		: p.server;
+
+	QUrlQuery q;
+	if (!p.security.isEmpty() && p.security != u"none"_q) {
+		q.addQueryItem(u"security"_q, p.security);
+	}
+	if (!p.flow.isEmpty()) {
+		q.addQueryItem(u"flow"_q, p.flow);
+	}
+	if (!p.transport.isEmpty() && p.transport != u"tcp"_q) {
+		q.addQueryItem(u"type"_q, p.transport);
+	}
+	if (!p.sni.isEmpty()) {
+		q.addQueryItem(u"sni"_q, p.sni);
+	}
+	if (!p.alpn.isEmpty()) {
+		q.addQueryItem(u"alpn"_q, p.alpn.join(QChar(',')));
+	}
+	if (!p.fingerprint.isEmpty()) {
+		q.addQueryItem(u"fp"_q, p.fingerprint);
+	}
+	if (!p.publicKey.isEmpty()) {
+		q.addQueryItem(u"pbk"_q, p.publicKey);
+	}
+	if (!p.shortId.isEmpty()) {
+		q.addQueryItem(u"sid"_q, p.shortId);
+	}
+	if (!p.path.isEmpty()) {
+		q.addQueryItem(u"path"_q, p.path);
+	}
+	if (!p.host.isEmpty()) {
+		q.addQueryItem(u"host"_q, p.host);
+	}
+	if (!p.serviceName.isEmpty()) {
+		q.addQueryItem(u"serviceName"_q, p.serviceName);
+	}
+	if (!p.headerType.isEmpty() && p.headerType != u"none"_q) {
+		q.addQueryItem(u"headerType"_q, p.headerType);
+	}
+	if (p.allowInsecure) {
+		q.addQueryItem(u"allowInsecure"_q, u"1"_q);
+	}
+
+	auto url = u"vless://"_q
+		+ encUuid + QChar('@')
+		+ encServer + QChar(':') + QString::number(p.port);
+	const auto query = q.query();
+	if (!query.isEmpty()) {
+		url += QChar('?') + query;
+	}
+	if (!p.name.isEmpty()) {
+		url += QChar('#') + QString::fromLatin1(
+			QUrl::toPercentEncoding(p.name));
+	}
+	return url;
+}
+
 QString BuildSingboxOutboundJson(const VlessParams &p) {
 	QJsonObject o;
 	o[u"type"_q]        = u"vless"_q;
diff --git a/Telegram/SourceFiles/mtproto/proxy/vless_parser.h b/Telegram/SourceFiles/mtproto/proxy/vless_parser.h
