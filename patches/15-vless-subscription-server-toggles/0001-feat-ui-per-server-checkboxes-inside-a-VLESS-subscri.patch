 void SubscriptionCache::setServers(
 		const QString &subscriptionUrl,
-		const QList<VlessParams> &servers) {
+		const QList<VlessParams> &fetched) {
 	QMutexLocker lock(&_mu);
 	ensureLoaded();
-	if (servers.isEmpty()) {
+	if (fetched.isEmpty()) {
 		_entries.erase(subscriptionUrl);
-	} else {
-		SubscriptionEntry entry;
-		entry.servers = servers;
-		entry.fetchedAt = QDateTime::currentDateTime();
-		_entries[subscriptionUrl] = std::move(entry);
+		persist();
+		return;
+	}
+	const auto previous = _entries.find(subscriptionUrl);
+	QHash<QString, bool> previousEnabled;
+	if (previous != _entries.end()) {
+		for (const auto &s : previous->second.servers) {
+			const auto key = BuildVlessUrl(s.params);
+			if (!key.isEmpty()) {
+				previousEnabled.insert(key, s.enabled);
+			}
+		}
+	}
+	SubscriptionEntry entry;
+	entry.fetchedAt = QDateTime::currentDateTime();
+	entry.servers.reserve(fetched.size());
+	for (const auto &p : fetched) {
+		const auto key = BuildVlessUrl(p);
+		const auto enabled = previousEnabled.value(key, true);
+		entry.servers.append({ p, enabled });
+	}
+	_entries[subscriptionUrl] = std::move(entry);
+	persist();
+}
+
+void SubscriptionCache::setServerEnabled(
+		const QString &subscriptionUrl,
+		int index,
+		bool enabled) {
+	QMutexLocker lock(&_mu);
+	ensureLoaded();
+	const auto it = _entries.find(subscriptionUrl);
+	if (it == _entries.end()
+		|| index < 0
+		|| index >= it->second.servers.size()) {
+		return;
+	}
+	if (it->second.servers[index].enabled == enabled) {
+		return;
 	}
+	it->second.servers[index].enabled = enabled;
 	persist();
 }
 
