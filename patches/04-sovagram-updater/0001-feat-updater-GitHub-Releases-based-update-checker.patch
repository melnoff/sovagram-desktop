diff --git a/Telegram/SourceFiles/core/sovagram_updater.cpp b/Telegram/SourceFiles/core/sovagram_updater.cpp
new file mode 100644
index 0000000000..05164be076
--- /dev/null
+++ b/Telegram/SourceFiles/core/sovagram_updater.cpp
@@ -0,0 +1,147 @@
+/*
+This file is part of Sovagram, a fork of Telegram Desktop.
+Licensed under GPLv3. See LEGAL for the original Telegram Desktop
+copyright notice and full license terms.
+*/
+#include "core/sovagram_updater.h"
+
+#include "base/call_delayed.h"
+#include "core/application.h"
+#include "core/file_utilities.h"
+#include "lang/lang_keys.h"
+#include "ui/boxes/confirm_box.h"
+#include "ui/toast/toast.h"
+#include "window/window_controller.h"
+#include "window/window_session_controller.h"
+
+#include <QtCore/QJsonArray>
+#include <QtCore/QJsonDocument>
+#include <QtCore/QJsonObject>
+#include <QtNetwork/QNetworkAccessManager>
+#include <QtNetwork/QNetworkReply>
+#include <QtNetwork/QNetworkRequest>
+
+#ifndef SOVAGRAM_BUILD_ID
+#define SOVAGRAM_BUILD_ID ""
+#endif
+
+#ifndef SOVAGRAM_RELEASES_REPO
+#define SOVAGRAM_RELEASES_REPO "melnoff/sovagram-desktop"
+#endif
+
+namespace Core::SovagramUpdater {
+namespace {
+
+constexpr auto kCheckDelay = crl::time(30 * 1000);
+
+[[nodiscard]] QString CurrentBuildId() {
+	return QString::fromLatin1(SOVAGRAM_BUILD_ID);
+}
+
+[[nodiscard]] QString ApiUrl() {
+	return QStringLiteral(
+		"https://api.github.com/repos/%1/releases/latest"
+	).arg(QStringLiteral(SOVAGRAM_RELEASES_REPO));
+}
+
+void NotifyNewVersion(const QString &tag, const QString &downloadUrl) {
+	auto toastText = tr::lng_sovagram_update_available(
+		tr::now,
+		lt_tag,
+		tag);
+	Ui::Toast::Show(toastText);
+
+	const auto window = Core::App().activeWindow();
+	if (!window) {
+		return;
+	}
+	window->show(Ui::MakeConfirmBox({
+		.text = tr::lng_sovagram_update_body(
+			lt_tag,
+			rpl::single(TextWithEntities{ tag }),
+			tr::rich),
+		.confirmed = [=](Fn<void()> close) {
+			File::OpenUrl(downloadUrl);
+			close();
+		},
+		.confirmText = tr::lng_sovagram_update_open(),
+		.cancelText = tr::lng_cancel(),
+		.title = tr::lng_sovagram_update_title(),
+	}));
+}
+
+[[nodiscard]] QString FindExeAssetUrl(const QJsonArray &assets) {
+	for (const auto &item : assets) {
+		const auto asset = item.toObject();
+		const auto name = asset.value(u"name"_q).toString();
+		if (name.startsWith(u"Sovagram"_q, Qt::CaseInsensitive)
+			&& name.endsWith(u".exe"_q, Qt::CaseInsensitive)) {
+			return asset.value(u"browser_download_url"_q).toString();
+		}
+	}
+	return QString();
+}
+
+void HandleLatestRelease(const QJsonObject &data) {
+	const auto tag = data.value(u"tag_name"_q).toString();
+	const auto releaseUrl = data.value(u"html_url"_q).toString();
+	const auto draft = data.value(u"draft"_q).toBool(false);
+	const auto prerelease = data.value(u"prerelease"_q).toBool(false);
+	if (tag.isEmpty() || releaseUrl.isEmpty() || draft || prerelease) {
+		return;
+	}
+	const auto current = CurrentBuildId();
+	if (current.isEmpty()) {
+		LOG(("SovagramUpdater: no build id, skipping check."));
+		return;
+	}
+	const auto short_current = current.left(7);
+	if (tag.contains(short_current)) {
+		LOG(("SovagramUpdater: already at latest (%1).").arg(tag));
+		return;
+	}
+	const auto exeUrl = FindExeAssetUrl(data.value(u"assets"_q).toArray());
+	const auto downloadUrl = exeUrl.isEmpty() ? releaseUrl : exeUrl;
+	LOG(("SovagramUpdater: new release %1 found, current build %2, "
+		"pointing user to %3."
+		).arg(tag, short_current, downloadUrl));
+	NotifyNewVersion(tag, downloadUrl);
+}
+
+void QueryApi() {
+	static auto manager = std::make_unique<QNetworkAccessManager>();
+	auto request = QNetworkRequest(QUrl(ApiUrl()));
+	request.setHeader(
+		QNetworkRequest::UserAgentHeader,
+		QStringLiteral("Sovagram-UpdateChecker"));
+	request.setRawHeader(
+		"Accept",
+		"application/vnd.github+json");
+	const auto reply = manager->get(request);
+	QObject::connect(reply, &QNetworkReply::finished, [=] {
+		reply->deleteLater();
+		if (reply->error() != QNetworkReply::NoError) {
+			LOG(("SovagramUpdater: network error %1"
+				).arg(reply->errorString()));
+			return;
+		}
+		const auto doc = QJsonDocument::fromJson(reply->readAll());
+		if (!doc.isObject()) {
+			return;
+		}
+		HandleLatestRelease(doc.object());
+	});
+}
+
+} // namespace
+
+void StartCheck() {
+	if (QString::fromLatin1(SOVAGRAM_BUILD_ID).isEmpty()) {
+		return;
+	}
+	base::call_delayed(kCheckDelay, [] {
+		QueryApi();
+	});
+}
+
+} // namespace Core::SovagramUpdater
