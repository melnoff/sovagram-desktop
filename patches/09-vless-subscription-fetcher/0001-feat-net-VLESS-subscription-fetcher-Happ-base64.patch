+
+#include <QtCore/QByteArray>
+#include <QtCore/QString>
+#include <QtCore/QUrl>
+#include <QtNetwork/QNetworkReply>
+#include <QtNetwork/QNetworkRequest>
+
+namespace MTP::Proxy {
+namespace {
+
+[[nodiscard]] QString TryBase64DecodeUrl(const QString &maybeBase64) {
+	const auto bytes = QByteArray::fromBase64(
+		maybeBase64.toLatin1(),
+		QByteArray::Base64UrlEncoding | QByteArray::OmitTrailingEquals);
+	if (bytes.isEmpty()) {
+		return QString();
+	}
+	const auto decoded = QString::fromUtf8(bytes).trimmed();
+	if (decoded.startsWith(u"http://"_q, Qt::CaseInsensitive)
+			|| decoded.startsWith(u"https://"_q, Qt::CaseInsensitive)) {
+		return decoded;
+	}
+	return QString();
+}
+
+[[nodiscard]] QList<VlessParams> ExtractVlessLines(const QString &text) {
+	QList<VlessParams> result;
+	const auto lines = text.split(QChar(u'\n'), Qt::SkipEmptyParts);
+	result.reserve(lines.size());
+	for (const auto &line : lines) {
+		const auto trimmed = line.trimmed();
+		if (!trimmed.startsWith(u"vless://"_q, Qt::CaseInsensitive)) {
+			continue;
+		}
+		if (auto parsed = ParseVlessUrl(trimmed)) {
+			result.append(std::move(*parsed));
+		}
+	}
+	return result;
+}
+
+} // namespace
+
+QString ResolveSubscriptionUrl(const QString &input) {
+	const auto trimmed = input.trimmed();
+	if (trimmed.isEmpty()) {
+		return QString();
+	}
+
+	if (trimmed.startsWith(u"http://"_q, Qt::CaseInsensitive)
+			|| trimmed.startsWith(u"https://"_q, Qt::CaseInsensitive)) {
+		return trimmed;
+	}
+
+	if (!trimmed.startsWith(u"happ://"_q, Qt::CaseInsensitive)) {
+		return QString();
+	}
+
+	const auto rest = trimmed.mid(QStringLiteral("happ://").size());
+	const auto slash = rest.indexOf(QChar(u'/'));
+	const auto payload = (slash < 0)
+		? QString()
+		: rest.mid(slash + 1).trimmed();
+	if (payload.isEmpty()) {
+		return QString();
+	}
+
+	if (payload.startsWith(u"http://"_q, Qt::CaseInsensitive)
+			|| payload.startsWith(u"https://"_q, Qt::CaseInsensitive)) {
+		return payload;
+	}
+	return TryBase64DecodeUrl(payload);
+}
+
+QList<VlessParams> ParseSubscriptionBody(const QByteArray &body) {
+	const auto raw = QString::fromUtf8(body);
+	const auto direct = ExtractVlessLines(raw);
+	if (!direct.isEmpty()) {
+		return direct;
+	}
+	const auto decoded = QByteArray::fromBase64(
+		body,
+		QByteArray::Base64Encoding | QByteArray::OmitTrailingEquals);
+	if (decoded.isEmpty()) {
+		return {};
+	}
+	return ExtractVlessLines(QString::fromUtf8(decoded));
+}
+
+SubscriptionFetcher::SubscriptionFetcher(QObject *parent)
+: QObject(parent) {
+}
+
+SubscriptionFetcher::~SubscriptionFetcher() {
+	cancel();
+}
+
+void SubscriptionFetcher::cancel() {
+	if (!_current) {
+		return;
+	}
+	_current->disconnect(this);
+	_current->abort();
+	_current->deleteLater();
+	_current = nullptr;
+}
+
+void SubscriptionFetcher::fetch(const QString &subscriptionUrl) {
+	cancel();
+	const auto resolved = ResolveSubscriptionUrl(subscriptionUrl);
+	if (resolved.isEmpty()) {
+		_done.fire({ {}, QStringLiteral("Invalid subscription URL.") });
+		return;
+	}
+	auto request = QNetworkRequest(QUrl(resolved));
+	request.setHeader(
+		QNetworkRequest::UserAgentHeader,
+		QStringLiteral("Sovagram-Subscription/1.0"));
+	request.setAttribute(
+		QNetworkRequest::RedirectPolicyAttribute,
+		QNetworkRequest::NoLessSafeRedirectPolicy);
+	const auto reply = _manager.get(request);
+	_current = reply;
+	QObject::connect(reply, &QNetworkReply::finished, this, [=] {
+		handleReply(reply);
+	});
+}
+
+void SubscriptionFetcher::handleReply(QNetworkReply *reply) {
+	reply->deleteLater();
+	if (reply != _current) {
+		return;
+	}
+	_current = nullptr;
+	if (reply->error() != QNetworkReply::NoError) {
+		LOG(("Subscription: fetch failed: %1").arg(reply->errorString()));
+		_done.fire({ {}, reply->errorString() });
+		return;
+	}
+	const auto body = reply->readAll();
+	auto servers = ParseSubscriptionBody(body);
+	if (servers.isEmpty()) {
+		_done.fire({ {}, QStringLiteral(
+			"No vless:// servers found in subscription.") });
+		return;
+	}
+	_done.fire({ std::move(servers), QString() });
+}
+
+rpl::producer<SubscriptionResult> SubscriptionFetcher::done() {
+	return _done.events();
+}
+
+} // namespace MTP::Proxy
