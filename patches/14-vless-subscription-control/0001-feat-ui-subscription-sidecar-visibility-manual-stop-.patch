+std::optional<VlessBridge::SocksEndpoint>
+VlessBridge::socksEndpointForSubscription(const QString &subscriptionKey) {
+	QMutexLocker lock(&_mu);
+	const auto it = _runningSubscriptions.find(subscriptionKey);
+	if (it == _runningSubscriptions.end()) {
+		return std::nullopt;
+	}
+	return SocksEndpoint{
+		.host = QStringLiteral("127.0.0.1"),
+		.port = it->second.port,
+	};
+}
+
