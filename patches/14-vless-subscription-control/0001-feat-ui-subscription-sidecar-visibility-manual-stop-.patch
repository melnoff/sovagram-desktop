+SubscriptionMonitorRegistry &SubscriptionMonitorRegistry::instance() {
+	static SubscriptionMonitorRegistry v;
+	return v;
+}
+
+SubscriptionMonitorRegistry::Entry &SubscriptionMonitorRegistry::ensureEntry(
+		const QString &url) {
+	auto it = _entries.find(url);
+	if (it != _entries.end()) {
+		return *it->second;
+	}
+	auto entry = std::make_unique<Entry>();
+	auto &ref = *entry;
+	_entries.emplace(url, std::move(entry));
+	return ref;
+}
+
+void SubscriptionMonitorRegistry::rebuildMonitor(const QString &url) {
+	auto endpoint = VlessBridge::instance().clashEndpointForSubscription(url);
+	auto it = _entries.find(url);
+	if (it == _entries.end()) {
+		return;
+	}
+	auto &entry = *it->second;
+
+	if (!endpoint) {
+		if (entry.monitor) {
+			entry.monitor.reset();
+			entry.monitorLifetime.destroy();
+			entry.stream.fire({}); // sidecarRunning = false
+		}
+		return;
+	}
+	if (entry.monitor && entry.monitor->endpoint() == endpoint->endpoint) {
+		return; // already running for this endpoint
+	}
+	entry.monitorLifetime.destroy();
+	entry.monitor = std::make_unique<SubscriptionMonitor>(
+		endpoint->endpoint,
+		endpoint->secret);
+	entry.monitor->status(
+	) | rpl::on_next([this, url](SubscriptionMonitorStatus s) {
+		auto it = _entries.find(url);
+		if (it != _entries.end()) {
+			it->second->stream.fire(std::move(s));
+		}
+	}, entry.monitorLifetime);
+	entry.monitor->start();
+}
+
+rpl::producer<SubscriptionMonitorStatus> SubscriptionMonitorRegistry::status(
+		const QString &subscriptionUrl) {
+	auto &entry = ensureEntry(subscriptionUrl);
+	rebuildMonitor(subscriptionUrl);
+	return entry.stream.events();
+}
+
+void SubscriptionMonitorRegistry::notifySidecarChanged(
+		const QString &subscriptionUrl) {
+	if (_entries.find(subscriptionUrl) == _entries.end()) {
+		return; // nobody listening
+	}
+	rebuildMonitor(subscriptionUrl);
+}
+
 } // namespace MTP::Proxy
