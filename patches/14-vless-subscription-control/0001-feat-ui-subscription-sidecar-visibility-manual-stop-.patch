+// Process-wide registry of subscription monitors. Hands out a single rpl
+// producer per subscription URL that emits status updates whenever the
+// sidecar polls or whenever sidecar state changes (start/stop).
+//
+// VlessBridge calls notifySidecarChanged() after ensureRunningSubscription /
+// stopSubscription so subscribers see "now connected" / "now idle" promptly.
+class SubscriptionMonitorRegistry final {
+public:
+	static SubscriptionMonitorRegistry &instance();
+
+	[[nodiscard]] rpl::producer<SubscriptionMonitorStatus> status(
+		const QString &subscriptionUrl);
+
+	void notifySidecarChanged(const QString &subscriptionUrl);
+
+private:
+	SubscriptionMonitorRegistry() = default;
+
+	struct Entry {
+		std::unique_ptr<SubscriptionMonitor> monitor;
+		rpl::event_stream<SubscriptionMonitorStatus> stream;
+		rpl::lifetime monitorLifetime;
+	};
+
+	[[nodiscard]] Entry &ensureEntry(const QString &url);
+	void rebuildMonitor(const QString &url);
+
+	base::flat_map<QString, std::unique_ptr<Entry>> _entries;
+};
+
 } // namespace MTP::Proxy
