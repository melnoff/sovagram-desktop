+std::optional<VlessBridge::Running> VlessBridge::startAndCollect(int id) {
+	if (id <= 0) {
+		if (_lastError && _freeString) {
+			if (char *err = _lastError()) {
+				LOG(("VLESS: sing-box start failed: %1"
+					).arg(QString::fromUtf8(err)));
+				_freeString(err);
+			}
+		}
+		return std::nullopt;
+	}
+	Running r;
+	r.id = id;
+	r.port = quint16(_getPort(id));
+	char *u = _getUser(id);
+	char *p = _getPass(id);
+	r.user = QString::fromUtf8(u ? u : "");
+	r.pass = QString::fromUtf8(p ? p : "");
+	if (u) _freeString(u);
+	if (p) _freeString(p);
+	return r;
+}
