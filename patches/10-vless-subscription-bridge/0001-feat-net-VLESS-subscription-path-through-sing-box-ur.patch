+
+ProxyData VlessBridge::ensureRunningSubscription(
+		const QString &subscriptionKey,
+		const QList<VlessParams> &servers) {
+	QMutexLocker lock(&_mu);
+
+	if (const auto it = _runningSubscriptions.find(subscriptionKey);
+			it != _runningSubscriptions.end()) {
+		return MakeSocks5(it->second.port, it->second.user, it->second.pass);
+	}
+
+	if (servers.isEmpty()) {
+		LOG(("VLESS: subscription has no servers (%1)").arg(subscriptionKey));
+		return {};
+	}
+
+	if (!ensureLoaded()) {
+		return {};
+	}
+
+	const auto outboundsJson = BuildSingboxSubscriptionOutboundsJson(servers);
+	if (outboundsJson.isEmpty()) {
+		LOG(("VLESS: subscription outbounds JSON is empty (%1)"
+			).arg(subscriptionKey));
+		return {};
+	}
+	const auto bytes = outboundsJson.toUtf8();
+	const auto running = startAndCollect(_startSub(bytes.constData()));
+	if (!running) {
+		return {};
+	}
+
+	_runningSubscriptions.emplace(subscriptionKey, *running);
+	LOG(("VLESS: subscription sidecar up for '%1' (%2 servers) on 127.0.0.1:%3"
+		).arg(subscriptionKey
+		).arg(servers.size()
+		).arg(running->port));
+
+	return MakeSocks5(running->port, running->user, running->pass);
 }
 
 void VlessBridge::stop(const QString &rawUrl) {
@@ -140,14 +184,26 @@ void VlessBridge::stop(const QString &rawUrl) {
 	_running.erase(it);
 }
 
+void VlessBridge::stopSubscription(const QString &subscriptionKey) {
+	QMutexLocker lock(&_mu);
+	const auto it = _runningSubscriptions.find(subscriptionKey);
+	if (it == _runningSubscriptions.end()) return;
+	if (_stop) _stop(it->second.id);
+	_runningSubscriptions.erase(it);
+}
+
 void VlessBridge::shutdownAll() {
 	QMutexLocker lock(&_mu);
 	if (_stop) {
 		for (const auto &[url, r] : _running) {
 			_stop(r.id);
 		}
+		for (const auto &[key, r] : _runningSubscriptions) {
+			_stop(r.id);
+		}
 	}
 	_running.clear();
+	_runningSubscriptions.clear();
 	// Do NOT unload the DLL — Go runtime doesn't survive DLL unload cleanly.
 	// The DLL will be released when the process exits.
 }
