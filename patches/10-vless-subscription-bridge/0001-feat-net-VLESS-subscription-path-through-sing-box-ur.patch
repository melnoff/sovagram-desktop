+//export SingboxStart
+func SingboxStart(outboundJSON *C.char) C.int {
+	setErr(nil)
+
+	outStr := C.GoString(outboundJSON)
+	if outStr == "" {
+		setErr(fmt.Errorf("empty outbound json"))
+		return 0
+	}
+
+	outbounds := "[" + outStr + `,{"type":"direct","tag":"direct"}]`
+	return startBoxWithOutbounds(outbounds)
+}
+
+//export SingboxStartSubscription
+func SingboxStartSubscription(outboundsArrayJSON *C.char) C.int {
+	setErr(nil)
+
+	arrStr := strings.TrimSpace(C.GoString(outboundsArrayJSON))
+	if arrStr == "" || !strings.HasPrefix(arrStr, "[") || !strings.HasSuffix(arrStr, "]") {
+		setErr(fmt.Errorf("invalid outbounds array json"))
+		return 0
+	}
+
+	inner := strings.TrimSpace(arrStr[1 : len(arrStr)-1])
+	var outbounds string
+	if inner == "" {
+		outbounds = `[{"type":"direct","tag":"direct"}]`
+	} else {
+		outbounds = "[" + inner + `,{"type":"direct","tag":"direct"}]`
+	}
+	return startBoxWithOutbounds(outbounds)
+}
+
 //export SingboxStop
 func SingboxStop(id C.int) C.int {
 	mu.Lock()
