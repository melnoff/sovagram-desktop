+#include "mtproto/proxy/subscription_cache.h"
+
+#include "logs.h"
+
+#include <QtCore/QDir>
+#include <QtCore/QFile>
+#include <QtCore/QJsonArray>
+#include <QtCore/QJsonDocument>
+#include <QtCore/QJsonObject>
+#include <QtCore/QMutexLocker>
+#include <QtCore/QStandardPaths>
+
+namespace MTP::Proxy {
+
+SubscriptionCache &SubscriptionCache::instance() {
+	static SubscriptionCache v;
+	return v;
+}
+
+SubscriptionCache::SubscriptionCache() = default;
+
+QString SubscriptionCache::StoragePath() {
+	const auto base = QStandardPaths::writableLocation(
+		QStandardPaths::AppDataLocation);
+	return QDir(base).absoluteFilePath(
+		QStringLiteral("sovagram_subscriptions.json"));
+}
+
+void SubscriptionCache::ensureLoaded() {
+	if (_loaded) {
+		return;
+	}
+	_loaded = true;
+
+	QFile file(StoragePath());
+	if (!file.exists() || !file.open(QIODevice::ReadOnly)) {
+		return;
+	}
+	const auto bytes = file.readAll();
+	file.close();
+
+	const auto doc = QJsonDocument::fromJson(bytes);
+	if (!doc.isObject()) {
+		return;
+	}
+	const auto subs = doc.object()
+		.value(u"subscriptions"_q).toObject();
+	for (auto it = subs.begin(); it != subs.end(); ++it) {
+		const auto entry = it.value().toObject();
+		const auto serversArray = entry.value(u"servers"_q).toArray();
+		QList<VlessParams> servers;
+		servers.reserve(serversArray.size());
+		for (const auto &v : serversArray) {
+			if (auto p = ParseVlessUrl(v.toString())) {
+				servers.append(std::move(*p));
+			}
+		}
+		if (!servers.isEmpty()) {
+			_entries.emplace(it.key(), std::move(servers));
+		}
+	}
+}
+
+void SubscriptionCache::persist() {
+	QJsonObject root;
+	QJsonObject subs;
+	for (const auto &[url, servers] : _entries) {
+		QJsonArray arr;
+		for (const auto &p : servers) {
+			const auto built = BuildVlessUrl(p);
+			if (!built.isEmpty()) {
+				arr.append(built);
+			}
+		}
+		QJsonObject entry;
+		entry[u"servers"_q] = arr;
+		subs[url] = entry;
+	}
+	root[u"subscriptions"_q] = subs;
+
+	const auto path = StoragePath();
+	QDir().mkpath(QFileInfo(path).absolutePath());
+	QFile file(path);
+	if (!file.open(QIODevice::WriteOnly | QIODevice::Truncate)) {
+		LOG(("SubscriptionCache: cannot write %1: %2"
+			).arg(path, file.errorString()));
+		return;
+	}
+	file.write(QJsonDocument(root).toJson(QJsonDocument::Compact));
+	file.close();
+}
+
+QList<VlessParams> SubscriptionCache::servers(
+		const QString &subscriptionUrl) {
+	QMutexLocker lock(&_mu);
+	ensureLoaded();
+	const auto it = _entries.find(subscriptionUrl);
+	return (it == _entries.end()) ? QList<VlessParams>() : it->second;
+}
+
+void SubscriptionCache::setServers(
+		const QString &subscriptionUrl,
+		const QList<VlessParams> &servers) {
+	QMutexLocker lock(&_mu);
+	ensureLoaded();
+	if (servers.isEmpty()) {
+		_entries.erase(subscriptionUrl);
+	} else {
+		_entries[subscriptionUrl] = servers;
+	}
+	persist();
+}
+
+void SubscriptionCache::clear(const QString &subscriptionUrl) {
+	QMutexLocker lock(&_mu);
+	ensureLoaded();
+	_entries.erase(subscriptionUrl);
+	persist();
+}
+
+} // namespace MTP::Proxy
