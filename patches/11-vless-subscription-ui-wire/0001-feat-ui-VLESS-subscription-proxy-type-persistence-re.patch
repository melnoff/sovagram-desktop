+
+// In-memory + disk-backed cache of fetched VLESS subscription server lists,
+// keyed by the user-visible subscription URL (happ:// or https://).
+//
+// Servers are persisted as vless:// strings in a single JSON file under the
+// application data dir; on next launch they are re-parsed via ParseVlessUrl.
+// This lets a Type::VlessSubscription proxy connect at startup using the
+// last known good server list, without requiring the user to open the
+// proxy edit dialog and refresh first.
+class SubscriptionCache final {
+public:
+	static SubscriptionCache &instance();
+
+	[[nodiscard]] QList<VlessParams> servers(
+		const QString &subscriptionUrl);
+
+	void setServers(
+		const QString &subscriptionUrl,
+		const QList<VlessParams> &servers);
+
+	void clear(const QString &subscriptionUrl);
+
+private:
+	SubscriptionCache();
+	~SubscriptionCache() = default;
+	SubscriptionCache(const SubscriptionCache &) = delete;
+	SubscriptionCache &operator=(const SubscriptionCache &) = delete;
+
+	void ensureLoaded();
+	void persist();
+
+	[[nodiscard]] static QString StoragePath();
+
+	QMutex _mu;
+	bool _loaded = false;
+	base::flat_map<QString, QList<VlessParams>> _entries;
+};
+
+} // namespace MTP::Proxy
