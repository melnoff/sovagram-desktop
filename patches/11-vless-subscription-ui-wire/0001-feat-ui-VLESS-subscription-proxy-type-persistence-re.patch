+void ProxyBox::setupVlessSubscriptionCredentials(const ProxyData &data) {
+	_vlessSubscriptionCredentials = _content->add(
+		object_ptr<Ui::SlideWrap<Ui::VerticalLayout>>(
+			_content,
+			object_ptr<Ui::VerticalLayout>(_content)));
+	const auto inner = _vlessSubscriptionCredentials->entity();
+
+	addLabel(inner, QStringLiteral("Subscription URL (Happ:// or https://)"));
+	_subUrl = inner->add(
+		object_ptr<Ui::InputField>(
+			inner,
+			st::connectionUserInputField,
+			Ui::InputField::Mode::NoNewlines,
+			rpl::single(QStringLiteral("happ://add/https://... or https://...")),
+			(data.type == Type::VlessSubscription) ? data.host : QString()),
+		st::proxyEditInputPadding);
+
+	const auto refreshBtn = inner->add(
+		object_ptr<Ui::LinkButton>(
+			inner,
+			QStringLiteral("Refresh now")),
+		st::proxyEditInputPadding);
+	refreshBtn->setClickedCallback([=] { refreshSubscription(); });
+
+	_subStatus = inner->add(
+		object_ptr<Ui::FlatLabel>(
+			inner,
+			QString(),
+			st::boxLabel),
+		st::proxyEditInputPadding + QMargins(0, 6, 0, 0));
+
+	_subServersLabel = inner->add(
+		object_ptr<Ui::FlatLabel>(
+			inner,
+			QStringLiteral("Click 'Refresh now' to load servers."),
+			st::boxLabel),
+		st::proxyEditInputPadding + QMargins(0, 4, 0, 8));
+
+	if (data.type == Type::VlessSubscription && !data.host.isEmpty()) {
+		const auto cached = MTP::Proxy::SubscriptionCache::instance()
+			.servers(data.host);
+		if (!cached.isEmpty()) {
+			QStringList names;
+			names.reserve(cached.size());
+			for (const auto &p : cached) {
+				names.append(p.name.isEmpty() ? p.server : p.name);
+			}
+			_subStatus->setText(QStringLiteral(
+				"Cached: %1 server(s).").arg(cached.size()));
+			_subServersLabel->setText(names.join(QChar(u'\n')));
+		}
+	}
+}
+
+void ProxyBox::refreshSubscription() {
+	if (!_subUrl || !_subStatus || !_subServersLabel) {
+		return;
+	}
+	const auto url = _subUrl->getLastText().trimmed();
+	if (url.isEmpty()) {
+		_subStatus->setText(QStringLiteral("Subscription URL is empty."));
+		return;
+	}
+	if (!_subFetcher) {
+		_subFetcher = std::make_unique<MTP::Proxy::SubscriptionFetcher>();
+		_subFetcher->done(
+		) | rpl::on_next([=](MTP::Proxy::SubscriptionResult result) {
+			if (!result.error.isEmpty()) {
+				_subStatus->setText(
+					QStringLiteral("Error: ") + result.error);
+				return;
+			}
+			MTP::Proxy::SubscriptionCache::instance().setServers(
+				url,
+				result.servers);
+			MTP::Proxy::VlessBridge::instance().stopSubscription(url);
+			_subStatus->setText(QStringLiteral(
+				"Loaded %1 server(s).").arg(result.servers.size()));
+			QStringList names;
+			names.reserve(result.servers.size());
+			for (const auto &p : result.servers) {
+				names.append(p.name.isEmpty() ? p.server : p.name);
+			}
+			_subServersLabel->setText(names.join(QChar(u'\n')));
+		}, lifetime());
+	}
+	_subStatus->setText(QStringLiteral("Fetching..."));
+	_subFetcher->fetch(url);
+}
