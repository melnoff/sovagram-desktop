From 1b3af4f42bfc2c0de69682f164a97fce75776c32 Mon Sep 17 00:00:00 2001
From: melnoff <melnoff360@gmail.com>
Date: Sun, 26 Apr 2026 16:30:18 +0300
Subject: [PATCH] feat(ui): scroll the subscription server list inside the
 proxy box
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Patch 16 — wraps the per-server checkbox VerticalLayout in a fixed-
height Ui::ScrollArea so subscriptions with many servers no longer
push the box past the screen height. The box itself stays the same
size; only the server-list region scrolls.
---
 Telegram/SourceFiles/boxes/connection_box.cpp | 9 +++++++--
 1 file changed, 7 insertions(+), 2 deletions(-)

diff --git a/Telegram/SourceFiles/boxes/connection_box.cpp b/Telegram/SourceFiles/boxes/connection_box.cpp
index deb4648530..6f42c4496b 100644
--- a/Telegram/SourceFiles/boxes/connection_box.cpp
+++ b/Telegram/SourceFiles/boxes/connection_box.cpp
@@ -44,6 +44,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "ui/widgets/menu/menu_add_action_callback.h"
 #include "ui/widgets/menu/menu_add_action_callback_factory.h"
 #include "ui/widgets/popup_menu.h"
+#include "ui/widgets/scroll_area.h"
 #include "ui/wrap/slide_wrap.h"
 #include "ui/wrap/table_layout.h"
 
@@ -1618,9 +1619,13 @@ void ProxyBox::setupVlessSubscriptionCredentials(const ProxyData &data) {
 			st::boxLabel),
 		st::proxyEditInputPadding + QMargins(0, 2, 0, 0));
 
-	_subServersInner = inner->add(
-		object_ptr<Ui::VerticalLayout>(inner),
+	const auto subScroll = inner->add(
+		object_ptr<Ui::ScrollArea>(inner, st::boxScroll),
 		st::proxyEditInputPadding + QMargins(0, 4, 0, 8));
+	subScroll->setFixedHeight(st::boxWideWidth);
+	_subServersInner = subScroll->setOwnedWidget(
+		object_ptr<Ui::VerticalLayout>(subScroll));
+	_subServersInner->resizeToWidth(st::boxWideWidth);
 
 	if (data.type == Type::VlessSubscription && !data.host.isEmpty()) {
 		_subUrlInUse = data.host;
-- 
